# Which forecast provider to use. Supported: "mock" (default), "open-meteo".
VITE_FORECAST_PROVIDER=mock

# Open-Meteo: no API key needed; base URL is configurable for self-hosted instances.
# VITE_OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
# Slow DNS or captive networks may need a longer timeout.
# VITE_OPEN_METEO_TIMEOUT_MS=15000

# Stormglass: requires an API key. Uncomment and add a real key when implemented.
# VITE_STORMGLASS_API_KEY=

# Wind grid source for the animated particle overlay on the Map page.
# Supported: "mock" (default). "noaa-gfs" is stubbed.
VITE_WIND_GRID_PROVIDER=mock

# Optional: URL of a serverless proxy that emits leaflet-velocity JSON when
# VITE_WIND_GRID_PROVIDER=noaa-gfs. See NoaaGfsWindGridProvider.ts for the
# expected payload shape.
# VITE_WIND_GRID_PROXY_URL=
